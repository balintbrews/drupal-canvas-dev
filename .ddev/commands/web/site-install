#!/bin/bash

## Description: Drupal Canvas: Install Drupal site.
## Aliases: si
## Usage: site-install [--ui] [-m|--mercury] [--stark]
## Example: "ddev site-install" or "ddev site-install --ui" or "ddev site-install -m" or "ddev site-install --stark"
## ExecRaw: true

set -e

cd "$DDEV_COMPOSER_ROOT/web/modules/contrib/canvas"
CANVAS_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || git rev-parse --short HEAD)
RECIPE_ROOT="$DDEV_COMPOSER_ROOT/recipes"

# Parse command line arguments.
UI=false
MERCURY=false
STARK=false
for arg in "$@"; do
    if [[ "$arg" == "--ui" ]]; then
        UI=true
    fi
    if [[ "$arg" == "--mercury" || "$arg" == "-m" ]]; then
        MERCURY=true
    fi
    if [[ "$arg" == "--stark" ]]; then
        STARK=true
    fi
done

apply_recipe() {
    pushd "$DDEV_COMPOSER_ROOT/$DDEV_DOCROOT" > /dev/null
    if [[ -x "$DDEV_COMPOSER_ROOT/vendor/bin/dr" ]]; then
        "$DDEV_COMPOSER_ROOT/vendor/bin/dr" recipe:apply --no-interaction "$1"
    else
        php core/scripts/drupal recipe --no-interaction "$1"
    fi
    popd > /dev/null
}

# Delete generated files that can leak container, route, or asset state between
# repeated reinstalls.
rm -rf \
    "$DDEV_COMPOSER_ROOT/web/sites/default/files/astro-island" \
    "$DDEV_COMPOSER_ROOT/web/sites/default/files/canvas" \
    "$DDEV_COMPOSER_ROOT/web/sites/default/files/css" \
    "$DDEV_COMPOSER_ROOT/web/sites/default/files/js" \
    "$DDEV_COMPOSER_ROOT/web/sites/default/files/php" \
    "$DDEV_COMPOSER_ROOT/web/sites/default/files/styles"

# Install Drupal.
drush site-install \
    --account-pass=admin \
    --site-name="Canvas [$CANVAS_BRANCH]" \
    --account-pass=admin \
    --yes

# Prevent automated cron from running while recipe commands terminate when the
# install profile enabled it.
if drush pm:list --type=module --status=enabled --field=name | grep -qx automated_cron; then
    drush config:set --yes automated_cron.settings interval 0
fi

# Enable modules.
# @todo Convert enabling modules into recipes.
MODULES="canvas canvas_headless canvas_dev_mode config default_content jsonapi jsonapi_menu_items admin_toolbar"
if [[ "$UI" == "true" ]]; then
    MODULES="$MODULES canvas_vite"
fi

drush pm:enable --yes $MODULES

# Apply recipes.
apply_recipe "$RECIPE_ROOT/canvas_dev_oauth"
# The OAuth recipe installs Simple OAuth in a separate PHP process. Rebuild the
# container before the next recipe boots Drupal so new entity types and
# procedural hooks are loaded.
drush cache:rebuild

if [[ "$MERCURY" == "false" ]]; then
    if [[ "$STARK" == "false" ]]; then
        apply_recipe "$RECIPE_ROOT/canvas_dev_humanify"
    else
        apply_recipe "$RECIPE_ROOT/canvas_dev_stark"
    fi
else
    apply_recipe "$RECIPE_ROOT/canvas_dev_mercury"
fi

# The theme recipes install a theme and set it as the default in a separate
# PHP process that leaves the persisted container stale. Since Drupal 11.4,
# theme negotiation checks the `container.themes` container parameter, so
# without a rebuild the new default theme is rejected and Canvas API requests
# fail with a missing `content` region.
drush cache:rebuild

# Generate OAuth keys.
drush simple-oauth:generate-keys /var/www/html/web/sites/default/files
# Resave the consumer entity (OAuth client) to update the secret, which gets
# encrypted using the generated keys.
drush php-eval "
    \$consumer = \Drupal::service('entity_type.manager')->getStorage('consumer')->loadByProperties(['client_id' => 'cli']);
    \$entity = reset(\$consumer);
    \$entity->set('secret', 'secret');
    \$entity->save();
"

# Build the UI when not using the Vite dev server.
if [[ "$UI" == "false" ]]; then
    npm install --prefix "$DDEV_COMPOSER_ROOT/web/modules/contrib/canvas"
    npm run build --prefix "$DDEV_COMPOSER_ROOT/web/modules/contrib/canvas/ui"
fi
