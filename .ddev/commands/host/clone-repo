#!/bin/bash

## Description: Drupal Canvas: Clone the Canvas module repository to the correct location.
## Usage: clone-repo
## Example: "ddev clone-repo"
## ExecRaw: true

set -euo pipefail

REPO_URL="git@git.drupal.org:project/canvas.git"
REPO_BRANCH="${CANVAS_BRANCH:-1.x}"
CONTRIB_DIR="$DDEV_APPROOT/web/modules/contrib"
TARGET_DIR="$DDEV_APPROOT/web/modules/contrib/canvas"
WIRE_CANVAS_AGENTS="$DDEV_APPROOT/scripts/wire-canvas-agents.sh"

wire_canvas_agents() {
    "$WIRE_CANVAS_AGENTS" "$TARGET_DIR"
}

restore_tracked_agent_file() {
    local tracked_file="$1"

    if ! git -C "$TARGET_DIR" ls-files --error-unmatch -- "$tracked_file" >/dev/null 2>&1; then
        return
    fi

    # Local instruction symlinks must be replaced before Git can update them.
    if [ -L "$TARGET_DIR/$tracked_file" ] || git -C "$TARGET_DIR" ls-files -v -- "$tracked_file" | grep -q "^S "; then
        git -C "$TARGET_DIR" update-index --no-skip-worktree -- "$tracked_file" 2>/dev/null || true
        git -C "$TARGET_DIR" checkout -- "$tracked_file"
    fi
}

restore_tracked_agent_files() {
    restore_tracked_agent_file AGENTS.md
    restore_tracked_agent_file CLAUDE.md
}

if [ ! -d "$TARGET_DIR" ] || [ -z "$(ls -A "$TARGET_DIR" 2>/dev/null)" ]; then
    echo "Directory $TARGET_DIR doesn't exist or is empty, cloning $REPO_BRANCH from $REPO_URL."
    
    # Create contrib directory if it doesn't exist.
    mkdir -p "$CONTRIB_DIR"
    
    git clone --branch "$REPO_BRANCH" "$REPO_URL" "$TARGET_DIR"
    echo "Repository cloned successfully to $TARGET_DIR."
else
    if ! git -C "$TARGET_DIR" rev-parse --git-dir >/dev/null 2>&1; then
        echo "Error: $TARGET_DIR already exists but is not a Git repository."
        exit 1
    fi

    echo "Directory $TARGET_DIR already exists, updating $REPO_BRANCH."

    restore_tracked_agent_files
    git -C "$TARGET_DIR" fetch origin

    if git -C "$TARGET_DIR" show-ref --verify --quiet "refs/heads/$REPO_BRANCH"; then
        git -C "$TARGET_DIR" checkout "$REPO_BRANCH"
    else
        git -C "$TARGET_DIR" checkout --track "origin/$REPO_BRANCH"
    fi

    git -C "$TARGET_DIR" merge --ff-only "origin/$REPO_BRANCH"
    echo "Repository updated successfully to $REPO_BRANCH."
fi

wire_canvas_agents
